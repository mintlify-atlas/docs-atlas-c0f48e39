  "keyFeatures": [
    "Unified C++/C/Python API for all USRP SDR hardware",
    "RX and TX streaming with timestamping and burst control",
    "Multi-USRP support for MIMO and synchronized configurations",
    "RFNoC (RF Network-on-Chip) FPGA processing framework",
    "Device discovery, identification, and address-based configuration",
    "Two-stage RF tuning with LO offset and DSP fine-tuning",
    "IQ calibration utilities for DC offset and IQ balance",
    "GPIO, timed commands, and hardware synchronization support",
    "UDP and PCIe transport layers with configurable parameters",
    "MPM (Module Peripheral Manager) for embedded USRP devices",
    "FPGA image management and image loader utility",
    "RFNoC ModTool and Image Builder for custom FPGA block development"
  ],
